{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Calendar Notes",
  "version": "0.1.0",
  "identifier": "com.calendar-notes.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Calendar Notes",
        "width": 1440,
        "height": 1100,
        "minWidth": 360,
        "minHeight": 620,
        "visible": true
      },
      {
        "label": "floating-note",
        "title": "悬浮便签",
        "width": 320,
        "height": 420,
        "minWidth": 280,
        "minHeight": 300,
        "decorations": false,
        "resizable": true,
        "skipTaskbar": true,
        "alwaysOnTop": true,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.ico"
    ]
  }
}
